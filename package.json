{
  "name": "pitch-therapy",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "typecheck:mobile": "npm run typecheck --workspace @pitch-therapy/mobile",
    "typecheck:core": "npm run typecheck --workspace @pitch-therapy/core",
    "typecheck:ui": "npm run typecheck --workspace @pitch-therapy/ui",
    "typecheck:web": "npm run typecheck --workspace @pitch-therapy/web",
    "typecheck:ci": "npm run typecheck:core && npm run typecheck:ui && npm run typecheck:mobile",
    "test": "turbo test",
    "doctor:mobile-resolution": "node ./scripts/doctor-mobile-resolution.js",
    "bundle:android:smoke": "cd apps/mobile && rm -rf .expo-smoke-export && NODE_PATH=\"$PWD/node_modules${NODE_PATH:+:$NODE_PATH}\" npx expo export --platform android --output-dir .expo-smoke-export",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "prettier": "^3.4.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=18"
  }
}
